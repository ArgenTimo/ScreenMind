OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

PROJECT_DIR=/absolute/path/to/I_can_help
DEFAULT_IMAGE_DIR=images
DEFAULT_LOG_DIR=logs
DEFAULT_PROMPT_PATH=prompts/default_prompt.txt
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_IMAGE=true
OUTPUT_LANGUAGE=en

# When true: Telegram sends two messages (debug inputs + Whisper text, then answer only). Session files are kept until listener restart.
DEBUG_TELEGRAM=false

# All screen_tool loggers also write to logs/service.log — monitor: tail -f logs/service.log

# Optional: OpenAI transcription model for WAV analysis (default whisper-1)
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Audio-only listener (run_audio_output_listener.sh): hold this key to record system output
AUDIO_OUTPUT_HOTKEY=f2

# Multimodal listener (run_multimodal_listener.sh): screenshot | hold record | submit last pair
# Use names like f9, f10, f12, scroll_lock (see pynput.keyboard.Key). Default submit is f12 (not f11).
MULTIMODAL_HOTKEY_IMAGE=f8
MULTIMODAL_HOTKEY_AUDIO=f9
MULTIMODAL_HOTKEY_SUBMIT=f10

# Set true to log every raw key press/release to logs/app.log (debugging "nothing happens")
MULTIMODAL_LOG_ALL_KEYS=true

# Optional: force pynput backend on Linux (default is Xorg). uinput may work on Wayland but often needs root.
# PYNPUT_BACKEND=uinput

# Log files: logs/app.log (rotating), logs/listeners.log (flushed), logs/listener_boot.log (early startup)