# Copy to .env and fill in values. Save the file after editing.
# Project root is detected automatically from the installation path (do not rely on PROJECT_DIR).

# --- Required ---
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- Telegram ---
# Leave empty on first run; the app can discover and save your chat id after you /start the bot.
TELEGRAM_CHAT_ID=
# Send the screenshot image to Telegram after the analysis text (true/false).
TELEGRAM_SEND_IMAGE=true

# --- OpenAI ---
OPENAI_MODEL=gpt-4.1-mini
# Used for session audio transcription (Whisper API).
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# --- Behavior ---
OUTPUT_LANGUAGE=en
LOG_LEVEL=INFO
# true = two Telegram messages (debug inputs + answer); keep captures until listener restarts. false = normal.
DEBUG_TELEGRAM=false

# Storage (relative to project root)
DEFAULT_IMAGE_DIR=images
DEFAULT_LOG_DIR=logs
DEFAULT_PROMPT_PATH=prompts/default_prompt.txt

# Session listener (./run_audio_output_listener.sh): pynput Key names (f8, f9, f2, f12, scroll_lock, …)
# If a line is blank, the default below is used. Do not use old AUDIO_OUTPUT_HOTKEY — set SESSION_HOTKEY_RECORD only.
SESSION_HOTKEY_RECORD=f8
SESSION_HOTKEY_SCREENSHOT=f9
SESSION_HOTKEY_SUBMIT=f2

# Optional: Linux only — see pynput docs if you need uinput on Wayland
# PYNPUT_BACKEND=uinput
